{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Bun application",
  "extends": "../base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ESNext"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ESNext",
    "types": ["bun"]
  }
}
