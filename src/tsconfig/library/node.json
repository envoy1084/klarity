{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node.js library",
  "extends": "../base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "target": "ES2022",
    "types": ["node"]
  }
}
