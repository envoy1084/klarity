{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Library (bundler-neutral source)",
  "extends": "./base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ES2022"
  }
}
