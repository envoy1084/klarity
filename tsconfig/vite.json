{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Vite application",
  "extends": "./app.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ES2022",
    "types": ["vite/client"]
  }
}
